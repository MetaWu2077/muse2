# =============================================================================
# Muse Cloud Server — 环境配置模板
# =============================================================================
# 复制本文件为 .env：  cp .env.example .env
# 启动：                python server.py
# 格式：等号右侧不要加英文引号、逗号；一行一个 KEY=value

# ----- 服务器 -----
MUSE_HOST=0.0.0.0
MUSE_PORT=8000
MUSE_LOG_LEVEL=info

# ----- MySQL 数据库 -----
# 云服务器上填写内网地址（同 VPC）
MUSE_MYSQL_HOST=172.27.0.6
MUSE_MYSQL_PORT=3306
MUSE_MYSQL_USER=root
MUSE_MYSQL_PASSWORD=
MUSE_MYSQL_DATABASE=muse_cloud
MUSE_MYSQL_POOL_SIZE=5

# ----- 原始数据文件存储 -----
MUSE_STORAGE_DIR=./muse_sessions
MUSE_MAX_SESSION_DURATION=7200

# ----- WebSocket 会话 -----
MUSE_WS_HEARTBEAT_TIMEOUT=60
MUSE_WS_MAX_SESSIONS=10
MUSE_DB_FLUSH_INTERVAL=1.0
