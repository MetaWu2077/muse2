<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/zen_bg"
    android:padding="20dp">

    <!-- Header -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ZEN FLOW"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/zen_text_main"
        android:letterSpacing="0.2"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Bento Tile: Bluetooth Connection -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_bluetooth"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="8dp"
        app:cardBackgroundColor="@color/zen_card"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/card_network">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_device_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No Device"
                android:textColor="@color/zen_text_main"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Searching..."
                android:textColor="@color/zen_text_secondary"
                android:textSize="11sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Bento Tile: Server Status -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_network"
        android:layout_width="0dp"
        android:layout_height="100dp"
        app:cardBackgroundColor="@color/zen_card"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toTopOf="@id/card_bluetooth"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/card_bluetooth">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp"
            android:gravity="center">

            <View
                android:id="@+id/v_cloud_dot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/shape_signal_dot"
                android:backgroundTint="@color/zen_warning" />

            <TextView
                android:id="@+id/tv_cloud_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="OFFLINE"
                android:textColor="@color/zen_text_main"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_battery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="--%"
                android:textColor="@color/zen_text_secondary"
                android:textSize="9sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Bento Tile: EEG Map -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_eeg_map"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="@color/zen_card"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/card_bluetooth"
        app:layout_constraintBottom_toTopOf="@+id/ll_bottom_controls">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="24dp">

            <View
                android:id="@+id/v_head_outline"
                android:layout_width="160dp"
                android:layout_height="200dp"
                android:background="@drawable/shape_signal_dot"
                android:backgroundTint="#0AFFFFFF"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <View
                android:id="@+id/dot_tp9"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:background="@drawable/shape_signal_dot"
                android:backgroundTint="@color/signal_off"
                app:layout_constraintBottom_toBottomOf="@id/v_head_outline"
                app:layout_constraintStart_toStartOf="@id/v_head_outline"
                android:layout_marginStart="-10dp"
                android:layout_marginBottom="40dp" />

            <View
                android:id="@+id/dot_af7"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:background="@drawable/shape_signal_dot"
                android:backgroundTint="@color/signal_off"
                app:layout_constraintTop_toTopOf="@id/v_head_outline"
                app:layout_constraintStart_toStartOf="@id/v_head_outline"
                android:layout_marginTop="20dp"
                android:layout_marginStart="30dp" />

            <View
                android:id="@+id/dot_af8"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:background="@drawable/shape_signal_dot"
                android:backgroundTint="@color/signal_off"
                app:layout_constraintTop_toTopOf="@id/v_head_outline"
                app:layout_constraintEnd_toEndOf="@id/v_head_outline"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="30dp" />

            <View
                android:id="@+id/dot_tp10"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:background="@drawable/shape_signal_dot"
                android:backgroundTint="@color/signal_off"
                app:layout_constraintBottom_toBottomOf="@id/v_head_outline"
                app:layout_constraintEnd_toEndOf="@id/v_head_outline"
                android:layout_marginEnd="-10dp"
                android:layout_marginBottom="40dp" />

            <!-- Sensors Icons -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent">
                <ImageView android:id="@+id/iv_sensor_ppg" android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_bluetooth_connect" android:layout_marginEnd="8dp" />
                <ImageView android:id="@+id/iv_sensor_acc" android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_bluetooth_searching" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Bottom Controls Area -->
    <LinearLayout
        android:id="@+id/ll_bottom_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Local Mode -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Local Mode"
                    android:textColor="@color/zen_text_secondary"
                    android:textSize="11sp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_local_mode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_local_ip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Phone IP: --"
                android:textColor="@color/zen_text_secondary"
                android:textSize="10sp" />

            <EditText
                android:id="@+id/et_local_target"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:hint="PC IP:5000 (from server orange text)"
                android:text="192.168.2.5:5000"
                android:textSize="12sp"
                android:textColor="@color/zen_text_main"
                android:textColorHint="@color/zen_text_secondary"
                android:inputType="text"
                android:imeOptions="actionDone"
                android:maxLines="1" />
        </LinearLayout>

        <!-- Timer -->
        <TextView
            android:id="@+id/tv_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textColor="@color/zen_text_main"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:visibility="gone"
            tools:visibility="visible" />

        <!-- EKG Waveform -->
        <com.musebridge.view.WaveformView
            android:id="@+id/v_waveform"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone"
            tools:visibility="visible" />

        <!-- Action Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_action"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="GO"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/zen_primary"
            app:cornerRadius="32dp" />
    </LinearLayout>

    <!-- Debug Log (Hidden) -->
    <ScrollView
        android:id="@+id/sv_log"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent">
        <TextView android:id="@+id/tv_data_log" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="8sp" android:textColor="#22FFFFFF" />
    </ScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_devices"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/ll_bottom_controls" />

</androidx.constraintlayout.widget.ConstraintLayout>
