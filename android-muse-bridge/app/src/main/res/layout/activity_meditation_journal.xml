<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/zen_bg"
    android:padding="20dp">

    <TextView
        android:id="@+id/tv_journal_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="禅修记录"
        android:textColor="@color/zen_text_main"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_journal_subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="请描述本次禅修的操作心法、过程中状态的变化，以及结束时到达的状态。"
        android:textColor="@color/zen_text_secondary"
        android:textSize="13sp"
        android:lineSpacingExtra="4dp"
        app:layout_constraintTop_toBottomOf="@id/tv_journal_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_session_info"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textColor="@color/zen_accent"
        android:textSize="12sp"
        app:layout_constraintTop_toBottomOf="@id/tv_journal_subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_journal"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="@color/zen_card"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/tv_session_info"
        app:layout_constraintBottom_toTopOf="@id/btn_submit_journal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            android:id="@+id/et_journal"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:gravity="top|start"
            android:hint="例如：\n00:00 开始 — 调整坐姿，关注呼吸\n05:00 — 杂念渐少，身体放松\n15:00 — 进入较稳定的状态\n结束时 — 感到..."
            android:inputType="textMultiLine|textCapSentences"
            android:padding="16dp"
            android:textColor="@color/zen_text_main"
            android:textColorHint="@color/zen_text_secondary"
            android:textSize="15sp"
            android:scrollbars="vertical" />
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_submit_journal"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="提交"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="28dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/ll_thank_you"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="感谢参与"
            android:textColor="@color/zen_accent"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="您的禅修数据与心得已保存。\n期待下次再见。"
            android:textColor="@color/zen_text_secondary"
            android:textSize="15sp"
            android:lineSpacingExtra="6dp" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progress_submit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/btn_submit_journal"
        app:layout_constraintBottom_toBottomOf="@id/btn_submit_journal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
